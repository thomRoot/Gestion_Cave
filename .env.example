# Configuration pour l'API Mistral
# Copiez ce fichier en .env et ajoutez votre clé API

# Clé API Mistral (obtenez-la sur https://console.mistral.ai/)
MISTRAL_API_KEY=votre_clé_api_ici

# Modèle à utiliser (optionnel)
# Options: mistral-tiny, mistral-small, mistral-medium
MISTRAL_MODEL=mistral-tiny