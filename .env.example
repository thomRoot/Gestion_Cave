# Configuration pour Ma Cave à Vin v5.0.0
# Copiez ce fichier en .env et remplissez avec vos clés API

# Clé API Mistral (obligatoire pour l'IA)
# Obtenez votre clé sur : https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=votre_clé_api_mistral

# Modèle Mistral à utiliser (optionnel)
# Options : mistral-tiny (gratuit), mistral-small, mistral-medium
MISTRAL_MODEL=mistral-tiny

# Clé API Google Vision (recommandée pour l'OCR des étiquettes)
# Obtenez votre clé sur : https://console.cloud.google.com/apis/credentials
# Gratuit jusqu'à 1000 requêtes/mois
GOOGLE_VISION_API_KEY=votre_clé_api_google_vision
